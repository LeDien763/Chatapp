# Auto detect text files
* text=auto

# Force LF for source code
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.html text eol=lf

# Shell scripts (deploy Linux)
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf

# Images / binary (không đổi line ending)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary